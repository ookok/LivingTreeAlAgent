{
  "scene_id": "writing",
  "scene_name": "写作助手",
  "description": "用户正在使用写作助手",

  "rules": [
    {
      "rule_id": "writer_block",
      "conditions": {
        "user_action": "遇到瓶颈"
      },
      "priority": 100,
      "template": {
        "emoji": "✍️",
        "title": "卡住了？",
        "content": "写作遇到瓶颈很正常的！试试让我帮你整理一下思路？",
        "level": "gentle"
      }
    },
    {
      "rule_id": "long_writing",
      "conditions": {
        "content_length": ">2000"
      },
      "priority": 60,
      "template": {
        "emoji": "📖",
        "title": "写了不少了",
        "content": "已经写了很长一段了！要不要休息一下，或者让我帮你润色一下？",
        "level": "glow"
      }
    },
    {
      "rule_id": "format_help",
      "conditions": {
        "user_action": "格式化"
      },
      "priority": 80,
      "template": {
        "emoji": "📝",
        "title": "格式化小技巧",
        "content": "可以用 Markdown 格式来组织内容，# 标题、## 小标题，清晰又方便～",
        "level": "glow"
      }
    }
  ],

  "chat_templates": {
    "intro": "写作中需要帮忙吗？",
    "questions": [
      "怎么开头更有吸引力？",
      "能帮我润色一下吗？",
      "怎么导出成其他格式？"
    ]
  },

  "hide_messages": {
    "temp": "好，专注写作～",
    "perma": "好的，写作页不再打扰你了 🌿"
  }
}
