{
  "scene_id": "low_performance",
  "scene_name": "性能问题",
  "description": "检测到系统性能下降",

  "rules": [
    {
      "rule_id": "high_cpu",
      "conditions": {
        "device_info.cpu_usage": ">80"
      },
      "priority": 80,
      "template": {
        "emoji": "🧠",
        "title": "系统有点累",
        "content": "CPU 占用有点高...关闭点后台任务会更流畅哦～",
        "level": "gentle"
      }
    },
    {
      "rule_id": "high_memory",
      "conditions": {
        "device_info.memory_usage": ">85"
      },
      "priority": 80,
      "template": {
        "emoji": "💾",
        "title": "内存有点紧",
        "content": "内存占用比较高...清理一下后台会更舒服～",
        "level": "gentle"
      }
    },
    {
      "rule_id": "high_gpu",
      "conditions": {
        "device_info.gpu_usage": ">90"
      },
      "priority": 85,
      "template": {
        "emoji": "🎮",
        "title": "显卡有点热",
        "content": "GPU 占用很高...是不是在跑什么大模型？注意散热哦～",
        "level": "gentle"
      }
    }
  ],

  "chat_templates": {
    "intro": "系统有点慢，想优化一下吗？",
    "questions": [
      "怎么查看系统资源占用？",
      "本地模型会影响性能吗？",
      "怎么优化系统速度？"
    ]
  },

  "hide_messages": {
    "temp": "好的，我不打扰～",
    "perma": "好的，性能提示不再打扰你了 🌿"
  }
}
