class LLMWikiIntegration:
    """
    LLM Wiki 集成器
    
    将 LLM Wiki 文档/论文解析器集成到现有 FusionRAG 系统。
    
    功能：
    1. 索引 Markdown 文档到 FusionRAG KnowledgeBase
    2. 索引 PDF 论文到 FusionRAG KnowledgeBase
    3. 提取并索引代码块
    4. 提供统一的搜索接口（复用 FusionRAG 四层架构）
    """
    
    def __init__(
    self,
    knowledge_base: Optional[KnowledgeBaseLayer] = None,
    chunk_optimizer: Optional[ChunkOptimizer] = None,
    fusion_engine: Optional[FusionEngine] = None
    ):
        """
    初始化集成器
    
    Args:
            knowledge_base: FusionRAG KnowledgeBaseLayer 实例（可选）
            chunk_optimizer: ChunkOptimizer 实例（可选）
            fusion_engine: FusionEngine 实例（可选）
    """
    if not FUSION_RAG_AVAILABLE:
            raise RuntimeError("FusionRAG 模块不可用，无法集成")
    
    # 使用现有的 FusionRAG 模块
    self.knowledge_base = knowledge_base or KnowledgeBaseLayer()
    self.chunk_optimizer = chunk_optimizer or ChunkOptimizer()
    self.fusion_engine = fusion_engine or FusionEngine()
    
    # Phase 1 解析器
    self.md_parser = LLMDocumentParser()
    self.paper_parser = PaperParser()
    self.code_extractor = CodeExtractor()
    
    # 统计
    self.indexed_documents = 0
    self.indexed_chunks = 0
    
    logger.info("LLMWikiIntegration 初始化完成")
    
    def index_markdown_document(
    self,
    file_path: str,
    metadata: Optional[Dict[str, Any]] = None
    ) -> Dict[str, Any]:
        """
    索引 Markdown 文档到 FusionRAG
    
    Args:
            file_path: Markdown 文件路径
            metadata: 额外元数据（可选）
            
    Returns:
            索引结果
    """
    logger.info(f"索引 Markdown 文档: {file_path}")
    
    try:
            # 1. 解析 Markdown 文档
            chunks = self.md_parser.parse_markdown(file_path)
            
            if not chunks:
                return {
                    "success": False,
                    "error": "未提取到任何内容块"
                }
            
            logger.info(f"  提取到 {len(chunks)} 个块")
            
            # 2. 存储到 FusionRAG KnowledgeBase（跳过优化，Phase 1 暂不需要）
            optimized_chunks = chunks  # 直接使用原始分块，跳过优化步骤
            
            logger.info(f"  分块数量: {len(optimized_chunks)} 个")
            
            # 3. 存储到 FusionRAG KnowledgeBase
            for chunk in optimized_chunks:
                # 合并元数据
                chunk_metadata = chunk.metadata.copy()
                if metadata:
                    chunk_metadata.update(metadata)
                chunk_metadata["source"] = file_path
                chunk_metadata["chunk_type"] = chunk.chunk_type
                self.knowledge_base.add_document(
                    content=chunk.content,
                    metadata=chunk_metadata
                )
            
            # 更新统计
            self.indexed_documents += 1
            self.indexed_chunks += len(optimized_chunks)
            
            logger.info(f"  ✅ 索引完成: {len(optimized_chunks)} 个块")
            
            return {
                "success": True,
                "file_path": file_path,
                "chunks_extracted": len(chunks),
                "chunks_indexed": len(optimized_chunks),
                "total_documents": self.indexed_documents,
                "total_chunks": self.indexed_chunks
            }
            
    except Exception as e:
            logger.error(f"索引 Markdown 文档失败: {e}")
            return {
                "success": False,
                "error": str(e)
            }
    
    def index_pdf_paper(
    self,
    file_path: str,
    paper_metadata: Optional[PaperMetadata] = None
    ) -> Dict[str, Any]:
        """
    索引 PDF 论文到 FusionRAG
    
    Args:
            file_path: PDF 文件路径
            paper_metadata: 论文元数据（可选，如果已提前获取）
            
    Returns:
            索引结果
    """
    logger.info(f"索引 PDF 论文: {file_path}")
    
    try:
            # 1. 解析 PDF
            parse_result = self.paper_parser.parse_pdf(file_path)
            
            if not parse_result.get("success"):
                return {
                    "success": False,
                    "error": parse_result.get("error")
                }
            
            # 2. 提取文本块
            chunks = parse_result.get("chunks", [])
            
            if not chunks:
                # 如果没有分块，从 text 字段创建块
                text = parse_result.get("text", "")
                if text:
                    chunks = self.paper_parser._chunk_text(text)
            
            logger.info(f"  提取到 {len(chunks)} 个块")
            
            # 3. 优化分块（跳过优化，Phase 1 暂不需要）
            optimized_chunks = chunks  # 直接使用原始分块，跳过优化步骤
            
            # 4. 准备元数据
            metadata = {
                "source": file_path,
                "type": "paper",
            }
            
            if paper_metadata:
                metadata["arxiv_id"] = paper_metadata.arxiv_id
                metadata["title"] = paper_metadata.title
                metadata["authors"] = paper_metadata.authors
                metadata["categories"] = paper_metadata.categories
            
            # 5. 存储到 FusionRAG KnowledgeBase
            for chunk in optimized_chunks:
                chunk_metadata = chunk.metadata.copy()
                chunk_metadata.update(metadata)
                self.knowledge_base.add_document(
                    content=chunk.content,
                    metadata=chunk_metadata
                )
            
            # 更新统计
            self.indexed_documents += 1
            self.indexed_chunks += len(optimized_chunks)
            
            logger.info(f"  ✅ 索引完成: {len(optimized_chunks)} 个块")
            
            return {
                "success": True,
                "file_path": file_path,
                "chunks_extracted": len(chunks),
                "chunks_indexed": len(optimized_chunks),
                "total_documents": self.indexed_documents,
                "total_chunks": self.indexed_chunks
            }
            
    except Exception as e:
            logger.error(f"索引 PDF 论文失败: {e}")
            return {
                "success": False,
                "error": str(e)
            }
    
    def index_code_blocks(
    self,
    file_path: str,
    language: str = "python"
    ) -> Dict[str, Any]:
        """
    提取并索引代码块到 FusionRAG
    
    Args:
            file_path: 文件路径（Markdown 或代码文件）
            language: 编程语言（如果已知）
            
    Returns:
            索引结果
    """
    logger.info(f"索引代码块: {file_path}")
    
    try:
            code_blocks = []
            
            # 判断文件类型
            if file_path.endswith(".md"):
                # Markdown 文件：提取代码块
                code_blocks = self.code_extractor.extract_from_markdown(file_path)
            else:
                # 代码文件：直接读取
                with open(file_path, 'r', encoding='utf-8') as f:
                    code = f.read()
                # 提取函数定义
                functions = self.code_extractor.extract_functions(code, language)
                # 转换为 DocumentChunk 格式
                for func in functions:
                    code_blocks.append({
                        "language": language,
                        "code": func["name"],
                        "length": len(func["name"])
                    })
            
            if not code_blocks:
                return {
                    "success": False,
                    "error": "未提取到任何代码块"
                }
            
            logger.info(f"  提取到 {len(code_blocks)} 个代码块")
            
            # 存储到 FusionRAG KnowledgeBase
            for i, block in enumerate(code_blocks):
                code_content = block if isinstance(block, str) else block.get("code", "")
                lang = block if isinstance(block, str) else block.get("language", "text")
                self.knowledge_base.add_document(
                    content=code_content,
                    metadata={
                        "source": file_path,
                        "chunk_type": "code",
                        "language": lang,
                        "type": "code_block"
                    }
                )
            
            # 更新统计
            self.indexed_chunks += len(code_blocks)
            
            logger.info(f"  ✅ 索引完成: {len(code_blocks)} 个代码块")
            
            return {
                "success": True,
                "file_path": file_path,
                "code_blocks_indexed": len(code_blocks),
                "total_chunks": self.indexed_chunks
            }
            
    except Exception as e:
            logger.error(f"索引代码块失败: {e}")
            return {
                "success": False,
                "error": str(e)
            }
    
    def search(
    self,
    query: str,
    top_k: int = 5,
    chunk_type: Optional[str] = None
    ) -> List[Dict[str, Any]]:
        """
    搜索 LLM Wiki（复用 FusionRAG 四层架构）
    
    Args:
            query: 查询字符串
            top_k: 返回结果数量
            chunk_type: 过滤块类型（可选："text", "code", "api", "paper"）
            
    Returns:
            搜索结果列表
    """
    logger.info(f"搜索 LLM Wiki: {query}")
    
    try:
            # 使用 FusionRAG 的 KnowledgeBase 搜索
            results = self.knowledge_base.search(query, top_k=top_k)
            
            # 过滤块类型（如果指定）
            if chunk_type:
                results = [r for r in results if r.get("metadata", {}).get("chunk_type") == chunk_type]
            
            logger.info(f"  找到 {len(results)} 个结果")
            
            return results
            
    except Exception as e:
            logger.error(f"搜索失败: {e}")
            return []
    
    def batch_index_directory(
    self,
    directory: str,
    file_extensions: List[str] = None
    ) -> Dict[str, Any]:
        """
    批量索引目录下的所有文档
    
    Args:
            directory: 目录路径
            file_extensions: 文件扩展名列表（如 [".md", ".pdf"]）
            
    Returns:
            批量索引结果
    """
    logger.info(f"批量索引目录: {directory}")
    
    if file_extensions is None:
            file_extensions = [".md", ".pdf", ".txt"]
    
    results = {
            "success": 0,
            "failed": 0,
            "skipped": 0,
            "details": []
    }
    
            try:
                for root, dirs, files in os.walk(directory):
                    for file in files:
                        file_path = os.path.join(root, file)
                        ext = os.path.splitext(file)[1].lower()
                        
                        if ext not in file_extensions:
                            results["skipped"] += 1
                            continue
                        # 根据文件类型调用不同的索引方法
                    if ext == ".md":
                        result = self.index_markdown_document(file_path)
                    elif ext == ".pdf":
                        result = self.index_pdf_paper(file_path)
                    else:
                        results["skipped"] += 1
                        continue
                        if result.get("success"):
                        results["success"] += 1
                    else:
                        results["failed"] += 1
                        results["details"].append(result)
            
            logger.info(f"  ✅ 批量索引完成: 成功 {results['success']}, 失败 {results['failed']}, 跳过 {results['skipped']}")
            
            return results
            
    except Exception as e:
            logger.error(f"批量索引失败: {e}")
            return {
                "success": 0,
                "failed": 0,
                "skipped": 0,
                "error": str(e)
            }
    
    def get_statistics(self) -> Dict[str, Any]:
        """
    获取索引统计信息
    
    Returns:
            统计信息字典
    """
    return {
            "indexed_documents": self.indexed_documents,
            "indexed_chunks": self.indexed_chunks,
            "knowledge_base_stats": self.knowledge_base.get_statistics() if hasattr(self.knowledge_base, 'get_statistics') else {}
    }


# 便捷函数
def create_llm_wiki_integration() -> LLMWikiIntegration:
    """
    便捷函数：创建 LLM Wiki 集成器
    
    Returns:
        LLMWikiIntegration 实例
    """
    return LLMWikiIntegration()

