/* LivingTree TUI — Full Textual theme */

Screen {
    background: $surface;
    color: $text;
    layers: base overlay;
}

#header {
    dock: top;
    height: 3;
    background: $panel;
    border-bottom: solid $primary;
    padding: 0 2;
    color: $text;
}

#header-title {
    width: 30;
    text-style: bold;
    color: $success;
}

#header-workspace {
    width: 1fr;
    color: $text-muted;
}

#header-status {
    width: 20;
    content-align: right middle;
    color: $success;
}

TabbedContent {
    height: 1fr;
}

TabPane {
    padding: 0;
}

Tab {
    padding: 0 2;
}

/* Chat layout: sidebar + main */
#sidebar {
    width: 26;
    background: $panel;
    border-right: solid $panel-darken-1;
    padding: 1 1;
}

#main-area {
    width: 1fr;
}

#task-title {
    color: $primary;
    text-style: bold;
    margin: 0 0 1 0;
}

StageIndicator {
    margin: 1 0;
}

#task-hint {
    color: $text-muted;
    margin: 1 0;
}

#task-cost {
    color: $text-muted;
    margin: 1 0;
}

/* Chat */
#chat-scroll {
    height: 1fr;
    border: none;
}

#chat-display {
    height: 1fr;
    border: none;
}

#chat-input-container {
    dock: bottom;
    height: auto;
    min-height: 3;
    max-height: 12;
    background: $panel;
    border-top: solid $primary;
    padding: 0 1;
}

#chat-input {
    border: none;
    min-height: 3;
}

#chat-input:focus {
    border: solid $primary;
}

#chat-hints {
    color: $text-muted;
    width: 1fr;
}

/* Code */
/* Code editor sidebar + main */
#code-sidebar {
    width: 28;
    background: $panel;
    border-right: solid $panel-darken-1;
    padding: 0 1;
}

#code-main {
    width: 1fr;
}

#code-tree {
    height: 1fr;
    overflow-y: auto;
}

#code-search {
    margin: 1 0;
}

#code-search:focus {
    border: solid $primary;
}

#code-file-info {
    color: $text-muted;
    height: 1;
    margin: 0;
}

#code-toolbar {
    height: 2;
    background: $panel;
    padding: 0 1;
}

#code-tabs {
    height: 1fr;
}

#code-output {
    height: 12;
    background: $panel;
    border-top: solid $primary;
    overflow-y: auto;
}

/* Docs */
#file-tree {
    width: 32;
    background: $panel;
    border-right: solid $panel-darken-1;
    scrollbar-size: 1 1;
}

#doc-preview {
    height: 1fr;
    border: none;
    scrollbar-size: 1 1;
}

/* Settings */
#settings-form {
    padding: 1 3;
    overflow-y: scroll;
    scrollbar-size: 1 1;
}

#settings-form Label {
    color: $text;
    margin: 1 0 0 0;
}

#settings-form Input {
    margin: 0 0 1 0;
}

#settings-form Input:focus {
    border: solid $primary;
}

/* Status bar */
#footer {
    dock: bottom;
    height: 1;
    background: $panel;
    border-top: solid $panel-darken-1;
    padding: 0 1;
}

#footer-keys {
    width: 1fr;
    color: $text-muted;
}

#footer-contact {
    width: 40;
    color: $primary;
    content-align: center middle;
}

#footer-status {
    width: 20;
    color: $success;
    content-align: right middle;
}

/* Command palette */
#palette-container {
    max-width: 52;
    max-height: 24;
    background: $panel;
    border: thick $primary;
    padding: 1;
    align: center middle;
}

#palette-input {
    margin: 1;
}

#palette-input:focus {
    border: solid $primary;
}

#palette-list {
    height: 16;
    margin: 1;
    background: $surface;
    overflow-y: scroll;
}

#palette-hint {
    color: $text-muted;
    text-style: italic;
    margin: 0 2;
}

/* DataTable */
DataTable {
    height: 1fr;
    scrollbar-size: 1 1;
}

DataTable > .datatable--header {
    text-style: bold;
    background: $panel-darken-1;
}

DataTable > .datatable--cursor {
    background: $primary 20%;
}

/* Buttons */
Button {
    margin: 0 1 0 0;
}

Button.primary {
    border: solid $primary;
}

/* Loading */
LoadingIndicator {
    height: 1;
}

/* Misc */
.chat-message-user {
    color: $success;
    text-style: bold;
    padding: 1 2 0;
}

.chat-message-ai {
    color: $text;
    padding: 0 2 0;
    background: $panel;
}

.chat-message-system {
    color: $text-muted;
    text-style: italic;
}

.chat-thinking {
    color: $primary-lighten-1;
    text-style: italic;
}

.help-panel {
    background: $panel;
    border: thick $primary;
    padding: 1 2;
    max-width: 60;
}

Select {
    margin: 0 1 0 0;
}

Input {
    margin: 0 1 0 0;
}
