# Force LF line endings for all text files
* text=auto eol=lf

# Python
*.py text eol=lf

# HTML/CSS/JS
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Config/YAML/TOML
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
