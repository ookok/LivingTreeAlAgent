{
  "id": "agent_reach",
  "name": "Agent-Reach Search",
  "desc": "免费联网搜索引擎，支持 Twitter/GitHub/Reddit/B站/网页读取",
  "enabled_by_default": true,
  "version": "1.0.0",
  "platforms": {
    "darwin_arm64": {
      "install_command": "pip install agent-reach && agent-reach install --env=auto",
      "bin_name": "agent-reach"
    },
    "darwin_amd64": {
      "install_command": "pip install agent-reach && agent-reach install --env=auto",
      "bin_name": "agent-reach"
    },
    "windows_amd64": {
      "install_command": "pip install agent-reach && agent-reach install --env=auto",
      "bin_name": "agent-reach.exe"
    },
    "linux_amd64": {
      "install_command": "pip install agent-reach && agent-reach install --env=auto",
      "bin_name": "agent-reach"
    }
  },
  "dependencies": {
    "python": ">=3.8",
    "system": ["curl"]
  },
  "capabilities": {
    "search": {
      "twitter": "搜索推文、读取单条推文",
      "github": "搜索仓库、查看仓库详情",
      "reddit": "搜索帖子、读取帖子全文",
      "bilibili": "搜索视频",
      "web": "Jina Reader 读取任意网页"
    },
    "free_tiers": {
      "exa": "语义搜索 (通过 MCP，免费额度)",
      "jina": "网页读取 (每日有限)"
    }
  },
  "config_env_vars": {
    "TWITTER_AUTH_TOKEN": "Twitter 登录令牌",
    "REDDIT_TOKEN": "Reddit 访问令牌"
  }
}
