{
  "app_name": "Living Tree AI",
  "version": "1.0.0",

  "description": "Living Tree AI 安全策略配置",

  "network": {
    "p2p_port_range": [40000, 60000],
    "relay_port": 8766,
    "web_ui_port": 8765,
    "lan_chat_range": [5000, 5100],

    "allowed_protocols": ["TCP", "UDP"],
    "bind_to_all_interfaces": true,

    "description": "网络端口配置 - 使用临时端口避免被阻止"
  },

  "firewall_rules": {
    "auto_add": true,
    "require_admin": true,

    "rules": [
      {
        "name": "Living Tree AI - P2P Discovery",
        "direction": "Inbound",
        "action": "Allow",
        "protocol": "UDP",
        "ports": "40000-60000",
        "description": "P2P 节点发现"
      },
      {
        "name": "Living Tree AI - Relay Server",
        "direction": "Inbound",
        "action": "Allow",
        "protocol": "TCP",
        "ports": "8766",
        "description": "中继服务器"
      },
      {
        "name": "Living Tree AI - Web UI",
        "direction": "Inbound",
        "action": "Allow",
        "protocol": "TCP",
        "ports": "8765",
        "description": "Web UI 访问"
      },
      {
        "name": "Living Tree AI - LAN Chat",
        "direction": "Inbound",
        "action": "Allow",
        "protocol": "UDP",
        "ports": "5000-5100",
        "description": "局域网聊天"
      }
    ],

    "description": "防火墙规则配置"
  },

  "antivirus": {
    "auto_exclude_defender": true,

    "trust_guides": {
      "windows_defender": {
        "url": "ms-settings:windowsdefender",
        "steps": [
          "打开 Windows 安全中心",
          "选择 '病毒和威胁防护'",
          "点击 '管理设置'",
          "将 Living Tree AI 添加到排除项"
        ]
      },

      "360": {
        "steps": [
          "打开 360 安全卫士",
          "点击 '病毒防护'",
          "进入 '信任管理'",
          "添加 Living Tree AI 目录"
        ]
      },

      "tencent": {
        "steps": [
          "打开腾讯电脑管家",
          "点击 '病毒查杀'",
          "选择 '信任区'",
          "添加 Living Tree AI"
        ]
      },

      "huorong": {
        "steps": [
          "打开火绒安全",
          "点击 '安全工具' > '信任管理'",
          "添加 Living Tree AI"
        ]
      }
    },

    "description": "杀毒软件信任配置"
  },

  "behavior_restrictions": {
    "restrict_to_appdata": true,

    "allowed_paths": [
      "%APPDATA%/LivingTreeAI",
      "%LOCALAPPDATA%/LivingTreeAI",
      "%TEMP%"
    ],

    "blocked_paths": [
      "C:\\Windows\\System32",
      "C:\\Windows\\SysWOW64",
      "C:\\Program Files"
    ],

    "description": "行为限制 - 防止误判为恶意软件"
  },

  "permissions": {
    "require_admin_for_network_change": true,
    "require_admin_for_firewall": true,

    "capabilities": [
      "network_access",
      "file_read_write",
      "ui_automation"
    ],

    "description": "权限配置"
  },

  "logging": {
    "enabled": true,
    "log_dir": "%APPDATA%/LivingTreeAI/logs",
    "max_log_size_mb": 50,
    "retention_days": 30,

    "event_types": [
      "network",
      "file_access",
      "registry",
      "process"
    ],

    "description": "行为日志配置"
  },

  "first_run": {
    "show_wizard": true,
    "auto_check_security": true,

    "wizard_steps": [
      "welcome",
      "firewall",
      "antivirus",
      "summary"
    ],

    "description": "首次运行配置"
  }
}