{
  "scene_id": "network_issue",
  "scene_name": "网络问题",
  "description": "检测到网络连接问题",

  "rules": [
    {
      "rule_id": "network_poor",
      "conditions": {
        "device_info.network": "poor"
      },
      "priority": 100,
      "template": {
        "emoji": "🌊",
        "title": "网络不太稳定",
        "content": "网络有点波动...先试试本地功能吧，我这边随时待命～",
        "level": "important"
      }
    },
    {
      "rule_id": "network_disconnected",
      "conditions": {
        "device_info.network": "disconnected"
      },
      "priority": 100,
      "template": {
        "emoji": "⚠️",
        "title": "好像断网了",
        "content": "网络断了！先用本地模式吧，有啥能帮的你随时说～",
        "level": "important"
      }
    },
    {
      "rule_id": "network_recovering",
      "conditions": {
        "device_info.network": "recovering"
      },
      "priority": 70,
      "template": {
        "emoji": "📶",
        "title": "网络正在恢复",
        "content": "网络在慢慢恢复～稍等一下就能用云模型了",
        "level": "glow"
      }
    }
  ],

  "chat_templates": {
    "intro": "网络不太稳定，想聊聊吗？",
    "questions": [
      "本地模型怎么用？",
      "离线模式下有什么功能？",
      "网络什么时候能恢复？"
    ]
  },

  "hide_messages": {
    "temp": "好的，我盯着呢～",
    "perma": "好的，网络问题页不再打扰你了 🌿"
  }
}
