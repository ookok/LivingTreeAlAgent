/* LivingTree TUI — polished theme */

Screen { background: $surface; color: $text; layers: base overlay; }

/* ═══ Title bar ═══ */
#title-bar {
    dock: top; height: 1;
    content-align: center middle; text-style: bold;
    color: $success; background: $panel;
    border-bottom: thick $success;
}

/* ═══ Search ═══ */
#card-search {
    dock: top; height: 1; margin: 0 4;
    border: solid $primary; background: $surface; color: $text;
}
#card-search:focus { border: solid $accent; }

/* ═══ Card layout ═══ */
#card-scroll { height: 1fr; overflow-y: auto; }
.card-row { height: auto; align-horizontal: center; padding: 1 4; }

/* ═══ Status bar ═══ */
StatusBar { dock: bottom; height: 2; background: $panel; border-top: solid $primary; padding: 0 2; }
#footer-keys { width: 1fr; color: $text-muted; }
#footer-status { width: 1fr; color: $success; content-align: right middle; }

/* ═══ Back link ═══ */
#back-link {
    dock: top; height: 1;
    color: $primary; padding: 0 2;
    background: $panel; border-bottom: solid $panel-darken-1;
}
#back-link:hover { color: $accent; text-style: bold; }

/* ═══ Module screens ═══ */
ChatScreen, CodeScreen, KnowledgeScreen, ToolsScreen, SettingsScreen { layout: vertical; height: 1fr; }

/* ═══ Chat ═══ */
#sidebar { width: 26; background: $panel; border-right: solid $panel-darken-1; padding: 1; }
#main-area { width: 1fr; }
#chat-display { height: 1fr; border: none; overflow-y: scroll; scrollbar-size: 1 1; padding: 0 1; }

#chat-input-container {
    dock: bottom; height: auto; min-height: 6; max-height: 14;
    background: $panel; border-top: thick $primary; padding: 1 1;
}
#chat-input {
    width: 1fr; height: 4; border: solid $panel-darken-1;
    background: $surface; padding: 0 1; margin: 0 1 0 0;
}
#chat-input:focus { border: solid $accent; }
#chat-hints { color: $text-muted; width: 1fr; margin: 0 0 0 1; }
#autocomplete-hint { height: 1; color: $text-muted; padding: 0 2; }

/* ═══ Code ═══ */
#code-sidebar { width: 28; background: $panel; border-right: solid $panel-darken-1; padding: 1; }
#code-main { width: 1fr; }
#code-tree { height: 1fr; overflow-y: auto; }
#code-search { height: 3; margin: 1 0; border: solid $primary; }
#code-search:focus { border: solid $accent; }
#code-file-info { color: $text-muted; height: 1; }
#code-toolbar { height: 2; background: $panel; padding: 0 1; }
#code-tabs { height: 1fr; }
#code-output { height: 12; background: $panel; border-top: solid $primary; overflow-y: auto; }

/* ═══ Help ═══ */
#help-content { height: 1fr; padding: 2 4; background: $panel; border: thick $accent; overflow-y: auto; }
#help-close { dock: bottom; margin: 1 0; }

/* ═══ Widgets ═══ */
Button { margin: 0 1 0 0; }
Button.primary { border: solid $primary; }
Input { height: 3; margin: 0 1 0 0; border: solid $panel-darken-1; background: $surface; }
Input:focus { border: solid $accent; }
Select { margin: 0 1 0 0; }
RichLog { border: none; padding: 0 1; }

/* ═══ DataTable ═══ */
DataTable { height: 1fr; scrollbar-size: 1 1; }
DataTable > .datatable--header { text-style: bold; background: $panel-darken-1; }
DataTable > .datatable--cursor { background: $primary 20%; }

/* ═══ Palette ═══ */
#palette-container { max-width: 52; max-height: 24; background: $panel; border: thick $primary; padding: 1; align: center middle; }
#palette-input { height: 3; margin: 1; }
#palette-input:focus { border: solid $accent; }
#palette-list { height: 16; margin: 1; background: $surface; overflow-y: scroll; }
#palette-hint { color: $text-muted; text-style: italic; margin: 0 2; }
