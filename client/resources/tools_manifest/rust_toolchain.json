{
  "id": "rust_toolchain",
  "name": "Rust Toolchain",
  "desc": "Rust 编译工具链 (Cargo) - 高性能 CLI 工具源码编译",
  "version": "1.86.0",
  "internal": true,
  "origin": "market",
  "enabled_by_default": false,
  "categories": ["runtime", "dependency"],
  "tags": ["rust", "cargo", "compiler", "cli-tools"],
  "platforms": {
    "windows_amd64": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-x86_64-pc-windows-msvc.msi",
      "bin_name": "cargo/bin/cargo.exe",
      "extract": true,
      "sha256": "",
      "installer_type": "rustup",
      "rustup_args": ["--profile", "minimal", "--default-toolchain", "stable"]
    },
    "windows_gnu": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-x86_64-pc-windows-gnu.msi",
      "bin_name": "cargo/bin/cargo.exe",
      "extract": true,
      "sha256": "",
      "installer_type": "rustup"
    },
    "darwin_amd64": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-x86_64-apple-darwin.tar.gz",
      "bin_name": "cargo/bin/cargo",
      "extract": true,
      "strip_components": 1,
      "sha256": "",
      "installer_type": "standalone"
    },
    "darwin_arm64": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-aarch64-apple-darwin.tar.gz",
      "bin_name": "cargo/bin/cargo",
      "extract": true,
      "strip_components": 1,
      "sha256": "",
      "installer_type": "standalone"
    },
    "linux_amd64": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-x86_64-unknown-linux-gnu.tar.gz",
      "bin_name": "cargo/bin/cargo",
      "extract": true,
      "strip_components": 1,
      "sha256": "",
      "installer_type": "standalone"
    },
    "linux_arm64": {
      "url": "https://static.rust-lang.org/dist/rust-1.86.0-aarch64-unknown-linux-gnu.tar.gz",
      "bin_name": "cargo/bin/cargo",
      "extract": true,
      "strip_components": 1,
      "sha256": "",
      "installer_type": "standalone"
    }
  },
  "runtime_config": {
    "cargo_home": "./tools/rust_toolchain/cargo",
    "rustup_home": "./tools/rust_toolchain/rustup",
    "default_toolchain": "stable",
    "targets": []
  },
  "install_hints": {
    "note": "Rust 工具链主要用于从源码编译特定工具。多数情况下直接下载预编译二进制即可。",
    "cargo_example": "cargo build --release",
    "rustup_example": "rustup default stable"
  }
}
