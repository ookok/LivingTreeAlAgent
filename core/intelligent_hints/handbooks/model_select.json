{
  "scene_id": "model_select",
  "scene_name": "模型选择",
  "description": "用户正在选择 AI 模型",

  "rules": [
    {
      "rule_id": "network_poor",
      "conditions": {
        "device_info.network": ["poor", "unstable", "disconnected"]
      },
      "priority": 100,
      "template": {
        "emoji": "🌊",
        "title": "网络有点波动",
        "content": "看你网络不太稳定，用本地 Ollama 会更稳哦，不怕掉线～",
        "level": "gentle"
      }
    },
    {
      "rule_id": "memory_high",
      "conditions": {
        "device_info.memory_usage": ">80"
      },
      "priority": 80,
      "template": {
        "emoji": "🧠",
        "title": "内存有点紧",
        "content": "内存占用有点高，试试轻量模型？Qwen2.5-0.5B 很省内存～",
        "level": "glow"
      }
    },
    {
      "rule_id": "free_user",
      "conditions": {
        "user_profile.prefers_free": true
      },
      "priority": 90,
      "template": {
        "emoji": "💰",
        "title": "省钱之选",
        "content": "想省点钱？DeepSeek 免费额度够用，中文能力也很强哦～",
        "level": "glow"
      }
    },
    {
      "rule_id": "speed_priority",
      "conditions": {
        "user_profile.prioritizes": "speed"
      },
      "priority": 90,
      "template": {
        "emoji": "🚀",
        "title": "极速响应",
        "content": "想要零延迟？Ollama 本地运行，你的设备完全带得动～",
        "level": "glow"
      }
    },
    {
      "rule_id": "power_user",
      "conditions": {
        "user_profile.prioritizes": "quality"
      },
      "priority": 90,
      "template": {
        "emoji": "✨",
        "title": "全能选手",
        "content": "想玩点强的？OpenRouter 聚合多模型，能力全面，适合尝鲜～",
        "level": "glow"
      }
    },
    {
      "rule_id": "compare_mode",
      "conditions": {
        "options_count": ">2",
        "user_action": "比较"
      },
      "priority": 70,
      "template": {
        "emoji": "📊",
        "title": "选择困难？",
        "content": "有 {option_count} 个选项不知道怎么挑？说说你的需求，我帮你参谋～",
        "level": "glow"
      }
    },
    {
      "rule_id": "first_time",
      "conditions": {
        "user_profile.is_new_user": true
      },
      "priority": 60,
      "template": {
        "emoji": "👋",
        "title": "第一次选模型？",
        "content": "不知道怎么选？新手推荐 Ollama 本地，简单稳定～",
        "level": "glow"
      }
    }
  ],

  "chat_templates": {
    "intro": "在模型选择页，有什么想了解的？",
    "questions": [
      "本地模型和云模型有什么区别？",
      "我的设备适合什么模型？",
      "哪个模型中文能力最强？"
    ]
  },

  "hide_messages": {
    "temp": "好，这次不打扰你了～",
    "perma": "好的，这个页面不会再闪了，有需要随时叫我 🌿"
  }
}
